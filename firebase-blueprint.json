{
  "entities": {
    "user": {
      "title": "User Profile",
      "description": "Information and configuration for a registered operator",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the operator" },
        "email": { "type": "string", "format": "email", "description": "Primary email for notifications" },
        "username": { "type": "string", "description": "Operational handle or display name" },
        "alertSettings": {
          "type": "object",
          "description": "Safety threshold boundaries",
          "properties": {
            "tempMax": { "type": "number" },
            "tempMin": { "type": "number" },
            "humidityMax": { "type": "number" },
            "humidityMin": { "type": "number" },
            "voltageMin": { "type": "number" },
            "voltageMax": { "type": "number" }
          }
        },
        "darkMode": { "type": "boolean", "description": "Display theme preference" }
      },
      "required": ["uid", "email", "username"]
    },
    "sensor_reading": {
      "title": "Sensor Reading",
      "description": "DHT11/22 & battery telemetric packet emitted by ESP32 node",
      "type": "object",
      "properties": {
        "temperature": { "type": "number" },
        "humidity": { "type": "number" },
        "voltage": { "type": "number" },
        "deviceId": { "type": "string", "maxLength": 128 },
        "status": { "type": "string", "enum": ["Normal", "Alert"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["temperature", "humidity", "voltage", "deviceId", "status", "timestamp"]
    },
    "alert": {
      "title": "Sensor Alert",
      "description": "System safety warning alert triggered when crossing bounds",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "sensorType": { "type": "string", "enum": ["temperature", "humidity", "voltage"] },
        "value": { "type": "number" },
        "threshold": { "type": "number" },
        "read": { "type": "boolean" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "sensorType", "value", "threshold", "read", "message", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "user",
      "description": "Root operator configurations"
    },
    "/users/{userId}/sensor_readings/{readingId}": {
      "schema": "sensor_reading",
      "description": "Real-time telemetry packets for this operator"
    },
    "/users/{userId}/alerts/{alertId}": {
      "schema": "alert",
      "description": "Historical triggered alarms for this operator"
    }
  }
}
